#!/bin/sh


get_dir() {
    if [ "$1" = "in" -o "$1" = "out" ]; then
        dir=$1
    else
        read -p'"in" or "out"? ' dir
        get_dir "$dir"
    fi
}

get_dir "$1"

if [ "$dir" = "in" ]; then
    echo "Dotfiles:"
    run-dot-git pull
    echo
    echo "Scripts:"
    git -C $HOME/scripts pull
    echo
    echo "Work:"
    git -C $HOME pull
    echo
    echo "Todo:"
    git -C $HOME/todo pull
    echo
    echo "Passwords:"
    git -C $HOME/.passwords  pull
elif [ "$dir" = "out" ]; then
    echo "Dotfiles:"
    sync-dot-repo
    echo
    echo "Scripts:"
    sync-repo $HOME/scripts
    echo
    echo "Work:"
    sync-repo $HOME
    echo
    echo "Todo:"
    sync-repo $HOME/todo
    echo
    echo "Passwords:"
    sync-repo $HOME/.passwords
fi
