#!/bin/sh

# arch
efibootmgr --disk /dev/nvme0n1\
	--part 1\
	--create\
	--label "Arch Linux"\
	--loader /vmlinuz-linux\
	--unicode\
		'root=PARTUUID=b825d628-e10b-4196-ac96-fcc58e874e76
		 resume=PARTUUID=7a961d3e-68a2-524c-b0c8-f6fb810bb0df
		 rw
		 initrd=\initramfs-linux.img'\
	--verbose

