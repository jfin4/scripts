#! /bin/sh
# status bar

# unicode blocks
bar18='\xe2\x96\x81' 
bar14='\xe2\x96\x82' 
bar24='\xe2\x96\x84' 
bar34='\xe2\x96\x86' 
bar44='\xe2\x96\x88' 
shade='\xe2\x96\x91'

# bar items
# network
Net() {
    sig=0
	if [ "$(ip address show wlan0 | grep 'inet[^6]')" ]
	then
		dbm=$(iw dev wlan0 link | awk '/signal/ { print $2 }')
		sig=$(( 2 * ( $dbm + 100 )))
	fi
	if [ $sig -ge 90 ]
	then
		var="$bar14$bar24$bar34$bar44 "
	elif [ $sig -ge 80 ]
	then
		var="$bar14$bar24$bar34$bar18 "
	elif [ $sig -ge 70 ]
	then
		var="$bar14$bar24$bar18$bar18 "
	elif [ $sig -ge 60 ]
	then
		var="$bar14$bar18$bar18$bar18 "
	elif [ $sig -ge 50 ]
	then
		var="$bar18$bar18$bar18$bar18 "
    else
        var="$bar18$bar18$bar18$bar18 (${sig}%) "
	fi
	echo -e "$var"
}

# battery
Bat() {
	cap=$(< /sys/class/power_supply/BAT0/capacity)
	if [ "$cap" -ge 90 ]
	then
		var="$bar44$bar44$bar44$bar44 "
	elif [ "$cap" -ge 75 ]
	then
		var="$bar44$bar44$bar44$shade "
	elif [ "$cap" -ge 50 ]
	then
		var="$bar44$bar44$shade$shade "
	elif [ "$cap" -ge 25 ]
	then
		var="$bar44$shade$shade$shade "
	elif [ "$cap" -ge 10 ]
	then
		var="$shade$shade$shade$shade "
	else
        var="$shade$shade$shade$shade ($cap%) "
	fi
    echo -e "$var"
}

# time
Time() {
	var="$(date '+%H:%M') "
	echo "$var" 
}

notify-send "$(Net)$(Bat)$(Time)"
