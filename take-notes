#!/usr/bin/zsh
# makes use of zsh-specific "print" command to print to command history

# process options
new=false
copy=false
key=1
reverse=reverse
pattern="${*:-.}"
OPTIND=1
while getopts 'nct' arg
do
    case "${arg}" in
        n) new=true ;;
        c) copy=true ;;
        t) key=2; reverse=""; pattern="#todo" ;;
        *) return ;;
    esac
done
shift $((OPTIND-1))

# if new note, edit new file and quit when finished
if $new
then
    dayno=$(date +'%y%j')
    i=a
    while [ -e $HOME/notes/${dayno}${i}.txt ]
    do
        if [ $i = "z" ]
        then
            echo "too many notes today"
            return 1
        else
            i=$(echo $i | tr "a-y" "b-z")
        fi
    done
    print -s vim $HOME/notes/${dayno}${i}.txt
    vim $HOME/notes/${dayno}${i}.txt
    return
fi

# otherwise, select file
cd $HOME/notes
clear
match=$(grep -ir "$pattern"\
    | sed -e 's/: \+/:/'\
    | sort --key=${key} --${reverse}\
    | fzy -l$(( LINES - 1 )))
file=${match%%:*}
line=${match##*:}
cd "$OLDPWD"

# if none selected, then do nothing and quit
if [ -z "$file" ]
then
    return
fi

# if all we want is the path, then send it to the clipboard and quit
if $copy
then
    echo -n $HOME/notes/$file > /dev/clipboard
    return
fi

# edit the selected file
print -s vim $HOME/notes/$file
vim -c "call search(\"$line\$\")" $HOME/notes/$file
