#!/bin/sh

OPTIND=1
while getopts 'nc' arg
do
    case "${arg}" in
        n) new=yes ;;
        c) copy=yes ;;
        *) return ;;
    esac
done
shift $((OPTIND-1))

if [ "$new" = yes ]; then
    dayno=$(date +'%y%j')
    i=1
    while [ -e $HOME/notes/${dayno}-${i}.txt ]
    do
        i=$(( i + 1 ))
    done

    vim $HOME/notes/${dayno}-${i}.txt
    echo print -s vim $HOME/notes/${dayno}-${i}.txt >> .zsh_history

    exit
fi

cd $HOME/notes
file=$(grep -ir "${1:-.}"\
    | sort -r\
    | fzy\
    | sed -e 's/:.*//')
cd "$OLDPWD"

if [ -z "$file" ]
then
    return
fi

if $copy
then
    print -n $HOME/notes/$file > /dev/clipboard
    return
fi

print -s vim $HOME/notes/$file
vim $HOME/notes/$file
