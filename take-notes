#!/bin/sh

dir="$PWD"
cd ~/notes

pat="$*"

if [ "$pat" = "." ]
then
	dayno=$(date +'%y-%j')

	i=1
	while [ -e $HOME/notes/${dayno}-${i}* ]
	do
		i=$(( i + 1 ))
	done

	vim $HOME/notes/${dayno}-${i}.txt

	exit
fi

if [ -z "$pat" ]
then
	pat="."
fi

file=$(grep -iar "$pat"\
	| sort -r\
	| fzy\
	| sed -e 's/:.*//')

if [ -n "$file" ]
then
	vim "$file"
fi

cd "$dir"
