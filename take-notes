#!/bin/sh

cd ~/notes

if [ "$1" = "." ]
then
	dayno=$(date +'%y-%j')

	i=1
	while [ -e $HOME/notes/${dayno}-${i}* ]
	do
		i=$(( i + 1 ))
	done

	vim $HOME/notes/${dayno}-${i}.txt

	exit
fi

file=$(grep --exclude-dir=".*" -r "${1:-.}"\
	| sort -r\
	| fzy\
	| sed -e 's/:.*//')

if [ -n "$file" ]
then
	vim "$file"
else
	exit
fi

